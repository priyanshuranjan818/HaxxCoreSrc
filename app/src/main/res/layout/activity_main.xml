<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:gravity="center"
    android:orientation="vertical">

    <!-- Main Card Container -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="15dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Subscription Timer Title - Modern Style -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Your Subscription Time Will End On"
                android:textColor="@color/blue"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="20dp"
                android:letterSpacing="0.02" />

            <!-- Modern Timer Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="10dp">

                <!-- Days Unit -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_uuid">

                    <TextView
                        android:id="@+id/tv_d"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="11"
                        android:textSize="28sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:gravity="center"
                        android:text="DAYS"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:textColor="@color/white"
                        android:alpha="0.9" />
                </LinearLayout>

                <!-- Separator -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="4dp"
                    android:text=":"
                    android:textSize="24sp"
                    android:textColor="@color/blue"
                    android:textStyle="bold"
                    android:layout_marginHorizontal="2dp" />

                <!-- Hours Unit -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_uuid">

                    <TextView
                        android:id="@+id/tv_h"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="09"
                        android:textSize="28sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:gravity="center"
                        android:text="HOURS"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:textColor="@color/white"
                        android:alpha="0.9" />
                </LinearLayout>

                <!-- Separator -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="4dp"
                    android:text=":"
                    android:textSize="24sp"
                    android:textColor="@color/blue"
                    android:textStyle="bold"
                    android:layout_marginHorizontal="2dp" />

                <!-- Minutes Unit -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_uuid">

                    <TextView
                        android:id="@+id/tv_m"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="14"
                        android:textSize="28sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:gravity="center"
                        android:text="MINUTES"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:textColor="@color/white"
                        android:alpha="0.9" />
                </LinearLayout>

                <!-- Separator -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="4dp"
                    android:text=":"
                    android:textSize="24sp"
                    android:textColor="@color/blue"
                    android:textStyle="bold"
                    android:layout_marginHorizontal="2dp" />

                <!-- Seconds Unit -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_uuid">

                    <TextView
                        android:id="@+id/tv_s"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="23"
                        android:textSize="28sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:gravity="center"
                        android:text="SECONDS"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:textColor="@color/white"
                        android:alpha="0.9" />
                </LinearLayout>
            </LinearLayout>

            <!-- Original TextView (hidden by default) -->
            <TextView
                android:id="@+id/textview21"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:paddingRight="5dp"
                android:paddingBottom="8dp"
                android:text=""
                android:textSize="13sp"
                android:textColor="@color/blue"
                android:visibility="gone" />

            <!-- Play Info Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_play_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="10dp"
                app:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/myIcon"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/pubg_india"
                            android:layout_marginEnd="12dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/Enc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Battle Ground Mobile India"
                                android:textSize="18sp"
                                android:textColor="@color/blue"
                                android:textStyle="bold"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/gameVersion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Version : 4.O"
                                android:textSize="12sp"
                                android:textColor="@color/blue" />

                            <TextView
                                android:id="@+id/gameContainerStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Status : Safe"
                                android:textSize="12sp"
                                android:textColor="@color/blue" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- PLAY GAME Button - Changed back to Button with original ID -->
                    <Button
                        android:id="@+id/starthack"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/rounded_button"
                        android:text="PLAY GAME"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:gravity="center" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/obb_progress_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:visibility="gone"
                android:max="100"
                style="?android:attr/progressBarStyleHorizontal"
                android:progress="0"
                android:progressTint="@color/blue" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_facebook_login"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/rounded_button"
                    android:text="Facebook Login"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btn_twitter_login"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/rounded_button"
                    android:text="Twitter Login"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>